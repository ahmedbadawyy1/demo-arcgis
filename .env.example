# Copy to .env and fill in locally. Never commit .env.

NODE_ENV=development
PORT=3000

# Windy defaults (also used by public/portal-windy.html query params if you self-host)
WINDY_DEFAULT_LAT=24.45
WINDY_DEFAULT_LON=54.38
WINDY_DEFAULT_ZOOM=6
WINDY_OVERLAY=wind

# ArcGIS & providers — use real values only in local .env
